<%
  wifi_entries = snapshot.payload["wifi"] || []
  ap_count     = wifi_entries.size
  ap_rows      = wifi_entries.first(15)
  z_time       = snapshot.payload["zTime"]
  observed_at  = z_time ? Time.at(z_time).utc : nil
%>

<div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold uppercase text-gray-400 mb-4">Latest Heeler Observation</h2>

  <dl class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Observation Time (UTC)</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= observed_at ? observed_at.iso8601 : "unknown" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">AP Beacons Observed</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800"><%= ap_count %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Site</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= snapshot.payload.dig("geoLoc", "site") || "—" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Platform</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= snapshot.payload["platform"] || "—" %>
      </dd>
    </div>
  </dl>

  <% if ap_rows.any? %>
    <h3 class="text-sm font-semibold text-gray-600 mb-2">
      WiFi AP Beacons
      <% if ap_count > 15 %>
        <span class="text-xs font-normal text-gray-400">(showing 15 of <%= ap_count %>)</span>
      <% end %>
    </h3>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm" data-testid="wifi-table">
        <thead class="bg-gray-50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-3 py-2 text-left">SSID</th>
            <th class="px-3 py-2 text-left">BSSID</th>
            <th class="px-3 py-2 text-right">Freq (MHz)</th>
            <th class="px-3 py-2 text-right">Signal (dBm)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% ap_rows.each do |ap| %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-mono"><%= ap["ssid"] %></td>
              <td class="px-3 py-2 font-mono text-gray-500"><%= ap["bssid"] %></td>
              <td class="px-3 py-2 text-right"><%= ap["frequency_mhz"] %></td>
              <td class="px-3 py-2 text-right"><%= ap["signal_dbm"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic">No WiFi AP beacons in this snapshot.</p>
  <% end %>
</div>
