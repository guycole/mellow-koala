<% content_for :title, "Admin Dashboard" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Admin Dashboard</h1>

  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded shadow p-6 text-center">
      <div class="text-4xl font-bold text-blue-600"><%= @task_count %></div>
      <div class="text-gray-600 mt-1">Tasks</div>
    </div>
    <div class="bg-white rounded shadow p-6 text-center">
      <div class="text-4xl font-bold text-green-600"><%= @box_score_count %></div>
      <div class="text-gray-600 mt-1">Box Scores</div>
    </div>
    <div class="bg-white rounded shadow p-6 text-center">
      <div class="text-4xl font-bold text-purple-600"><%= @import_log_count %></div>
      <div class="text-gray-600 mt-1">Import Logs</div>
    </div>
  </div>

  <h2 class="text-lg font-semibold text-gray-700 mb-3">Recent Imports</h2>
  <div class="bg-white rounded shadow overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
        <tr>
          <th class="px-4 py-3 text-left">Source File</th>
          <th class="px-4 py-3 text-left">Type</th>
          <th class="px-4 py-3 text-left">Run At</th>
          <th class="px-4 py-3 text-right">Processed</th>
          <th class="px-4 py-3 text-right">Inserted</th>
          <th class="px-4 py-3 text-right">Skipped</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @recent_imports.each do |log| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-mono text-xs"><%= log.source_file %></td>
            <td class="px-4 py-3"><%= log.import_type %></td>
            <td class="px-4 py-3 text-gray-600"><%= log.run_at&.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td class="px-4 py-3 text-right"><%= log.records_processed %></td>
            <td class="px-4 py-3 text-right"><%= log.records_inserted %></td>
            <td class="px-4 py-3 text-right"><%= log.records_skipped %></td>
          </tr>
        <% end %>
        <% if @recent_imports.empty? %>
          <tr><td colspan="6" class="px-4 py-6 text-center text-gray-400">No imports yet</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%= link_to "View All Import Logs", admin_import_logs_path, class: "text-blue-600 hover:underline" %>
  </div>
</div>
