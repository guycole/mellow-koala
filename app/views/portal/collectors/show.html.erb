<div class="max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-800"><%= @collector.display_name %></h1>
      <p class="text-sm text-gray-500 mt-1">ID: <code class="bg-gray-100 px-1 rounded"><%= @collector.collector_id %></code></p>
    </div>
    <% if @collector.stale? %>
      <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-800">⚠ Stale</span>
    <% else %>
      <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">✓ Fresh</span>
    <% end %>
  </div>

  <% if @latest_config.nil? %>
    <div class="rounded-lg border border-dashed border-gray-300 p-10 text-center">
      <p class="text-gray-500">No configuration snapshots available yet.</p>
    </div>
  <% else %>
    <div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold uppercase text-gray-400 mb-3">Latest Configuration Snapshot</h2>
      <p class="text-xs text-gray-500 mb-3">Received: <strong><%= @latest_config.received_at&.utc&.iso8601 %></strong></p>
      <pre class="bg-gray-50 rounded p-4 text-sm overflow-x-auto text-gray-700"><%= JSON.pretty_generate(@latest_config.payload) rescue @latest_config.payload.to_s %></pre>
    </div>

    <% if @config_history.length > 1 %>
      <div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6">
        <h2 class="text-sm font-semibold uppercase text-gray-400 mb-3">History (last 10)</h2>
        <ul class="divide-y divide-gray-100">
          <% @config_history.each do |snap| %>
            <li class="py-2 flex justify-between text-sm">
              <code class="text-gray-600"><%= snap.snapshot_id %></code>
              <span class="text-gray-400"><%= snap.received_at&.utc&.iso8601 %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
