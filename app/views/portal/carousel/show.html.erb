<%# Auto-advance via meta refresh %>
<meta http-equiv="refresh" content="<%= @dwell %>; url=<%= @next_url %>">

<div class="max-w-4xl">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-xs bg-indigo-100 text-indigo-700 px-2 py-1 rounded font-medium">🔄 Carousel</span>
      <span class="text-xs text-gray-400">Advancing in <span id="carousel-countdown"><%= @dwell %></span>s → <%= @next_url %></span>
    </div>
    <%= link_to "Stop Carousel", root_path, class: "text-xs text-red-500 hover:text-red-700 underline" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-800 mb-2"><%= @collector.display_name %></h1>
  <p class="text-sm text-gray-500 mb-6">ID: <code class="bg-gray-100 px-1 rounded"><%= @collector.collector_id %></code></p>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6">
      <h2 class="text-sm font-semibold uppercase text-gray-400 mb-3">Latest Configuration</h2>
      <% if @latest_config %>
        <p class="text-xs text-gray-500 mb-2"><%= @latest_config.received_at&.utc&.iso8601 %></p>
        <pre class="bg-gray-50 rounded p-3 text-xs overflow-x-auto text-gray-700 max-h-64"><%= JSON.pretty_generate(@latest_config.payload) rescue @latest_config.payload.to_s %></pre>
      <% else %>
        <p class="text-gray-400 italic text-sm">No configuration yet</p>
      <% end %>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6">
      <h2 class="text-sm font-semibold uppercase text-gray-400 mb-3">Latest Collection</h2>
      <% if @latest_collection %>
        <p class="text-xs text-gray-500 mb-2"><%= @latest_collection.received_at&.utc&.iso8601 %></p>
        <pre class="bg-gray-50 rounded p-3 text-xs overflow-x-auto text-gray-700 max-h-64"><%= JSON.pretty_generate(@latest_collection.payload) rescue @latest_collection.payload.to_s %></pre>
      <% else %>
        <p class="text-gray-400 italic text-sm">No collection data yet</p>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Optional: countdown display
  var remaining = <%= @dwell %>;
  var el = document.getElementById("carousel-countdown");
  if (el) {
    setInterval(function() {
      remaining--;
      if (remaining >= 0 && el) el.textContent = remaining;
    }, 1000);
  }
</script>
