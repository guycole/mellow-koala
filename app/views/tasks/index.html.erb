<% content_for :title, "Tasks" %>

<div class="max-w-6xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-800 mb-4">Tasks</h1>

  <%= form_with url: tasks_path, method: :get, class: "flex gap-3 mb-6" do %>
    <%= text_field_tag :name, params[:name], placeholder: "Filter by name", class: "border rounded px-3 py-2 flex-1" %>
    <%= text_field_tag :host, params[:host], placeholder: "Filter by host", class: "border rounded px-3 py-2 flex-1" %>
    <%= submit_tag "Filter", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Clear", tasks_path, class: "text-gray-600 px-3 py-2 hover:underline" %>
  <% end %>

  <div class="bg-white rounded shadow overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
        <tr>
          <th class="px-4 py-3 text-left"><%= link_to "Name", tasks_path(params.permit(:name, :host).merge(sort: "name", direction: params[:sort] == "name" && params[:direction] == "asc" ? "desc" : "asc")), class: "hover:underline" %></th>
          <th class="px-4 py-3 text-left"><%= link_to "Host", tasks_path(params.permit(:name, :host).merge(sort: "host", direction: params[:sort] == "host" && params[:direction] == "asc" ? "desc" : "asc")), class: "hover:underline" %></th>
          <th class="px-4 py-3 text-left"><%= link_to "Start Time", tasks_path(params.permit(:name, :host).merge(sort: "start_time", direction: params[:sort] == "start_time" && params[:direction] == "asc" ? "desc" : "asc")), class: "hover:underline" %></th>
          <th class="px-4 py-3 text-left">Duration</th>
          <th class="px-4 py-3 text-left">UUID</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tasks.each do |task| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= task.name %></td>
            <td class="px-4 py-3 text-gray-600"><%= task.host %></td>
            <td class="px-4 py-3 text-gray-600"><%= task.start_time&.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td class="px-4 py-3">
              <% if task.stop_time.nil? %>
                <span class="text-green-600 font-medium">In Progress</span>
              <% else %>
                <%= task.duration_display %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-400 text-xs font-mono"><%= task.uuid %></td>
          </tr>
        <% end %>
        <% if @tasks.empty? %>
          <tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">No tasks found</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-4 flex justify-center gap-2">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

  <p class="mt-2 text-sm text-gray-500">Showing <%= @pagy.count %> total tasks</p>
</div>
