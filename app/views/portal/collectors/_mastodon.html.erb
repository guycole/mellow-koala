<%
  epoch_seconds = snapshot.payload["epochSeconds"] || snapshot.payload["zTime"]
  observed_at   = if epoch_seconds
    Time.at(epoch_seconds.to_f).utc
  else
    snapshot.captured_at&.utc || snapshot.received_at&.utc
  end
  observed_label = observed_at ? observed_at.strftime("%Y-%m-%d %H:%M:%S UTC") : "unknown"
  peakers     = snapshot.payload["peakers"]
  hostname = snapshot.payload["hostname"] || snapshot.payload["hostName"] || snapshot.payload["platform"]
%>

<div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold uppercase text-gray-400 mb-4">Latest Mastodon Observation</h2>

  <dl class="grid grid-cols-2 gap-4">
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Observation Time (UTC)</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= observed_label %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Peakers</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800"><%= peakers.nil? ? "—" : peakers %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Site</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= snapshot.payload.dig("geoLoc", "site") || "—" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Hostname</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= hostname || "—" %>
      </dd>
    </div>
  </dl>
</div>
