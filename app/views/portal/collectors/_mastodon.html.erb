<%
  epoch_seconds = snapshot.payload["epochSeconds"] || snapshot.payload["zTime"]
  observed_at   = if epoch_seconds
    Time.at(epoch_seconds.to_f).utc
  else
    snapshot.captured_at&.utc || snapshot.received_at&.utc
  end
  observed_label = observed_at ? observed_at.strftime("%Y-%m-%d %H:%M:%S UTC") : "unknown"
  peakers     = snapshot.payload["peakers"] || []
  peaker_count = peakers.size
  peaker_rows  = peakers.first(15)
  hostname = snapshot.payload["hostname"] || snapshot.payload["hostName"] || snapshot.payload["platform"]
%>

<div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold uppercase text-gray-400 mb-4">Latest Mastodon Observation</h2>

  <dl class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Observation Time (UTC)</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= observed_label %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Peakers Observed</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800"><%= peaker_count %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Site</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= snapshot.payload.dig("geoLoc", "site") || "—" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Hostname</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= hostname || "—" %>
      </dd>
    </div>
  </dl>

  <% if peaker_rows.any? %>
    <h3 class="text-sm font-semibold text-gray-600 mb-2">
      Peakers
      <% if peaker_count > 15 %>
        <span class="text-xs font-normal text-gray-400">(showing 15 of <%= peaker_count %>)</span>
      <% end %>
    </h3>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm" data-testid="mastodon-peakers-table">
        <thead class="bg-gray-50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-3 py-2 text-left">Frequency (Hz)</th>
            <th class="px-3 py-2 text-right">Count</th>
            <th class="px-3 py-2 text-right">Avg Power (dB)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% peaker_rows.each do |peaker| %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-mono"><%= peaker[0] %></td>
              <td class="px-3 py-2 text-right"><%= peaker[1] %></td>
              <td class="px-3 py-2 text-right"><%= peaker[2]&.round(2) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic">No peakers in this snapshot.</p>
  <% end %>

  <details class="mt-6 border-t border-gray-100 pt-4" data-testid="mastodon-raw-json">
    <summary class="cursor-pointer text-sm font-semibold text-gray-600 hover:text-gray-800">
      Raw Payload JSON
    </summary>
    <pre class="mt-3 bg-gray-50 rounded p-4 text-sm overflow-x-auto text-gray-700"><%= JSON.pretty_generate(snapshot.payload) rescue snapshot.payload.to_s %></pre>
  </details>
</div>
