<%
  source_payload = snapshot.payload["payload"].is_a?(Hash) ? snapshot.payload["payload"] : snapshot.payload
  observations = source_payload["observation"] || []
  obs_count    = observations.size
  obs_rows     = observations.first(15)
  raw_adsbex = source_payload["adsbex"]
  adsbex_index = case raw_adsbex
  when Hash
    raw_adsbex.transform_keys { |k| k.to_s.downcase }
  when Array
    raw_adsbex.each_with_object({}) do |entry, index|
      next unless entry.is_a?(Hash)

      hex = entry["adsbHex"] || entry["adsb_hex"] || entry["hex"]
      next if hex.blank?

      index[hex.to_s.downcase] = entry
    end
  else
    {}
  end
  epoch_seconds = snapshot.payload["epochSeconds"] || snapshot.payload["zTime"] || snapshot.payload.dig("meta", "timeStampEpoch")
  observed_at   = if epoch_seconds
    Time.at(epoch_seconds.to_f).utc
  else
    snapshot.captured_at&.utc || snapshot.received_at&.utc
  end
  observed_label = observed_at ? observed_at.strftime("%Y-%m-%d %H:%M:%S UTC") : "unknown"
  hostname = snapshot.payload["hostname"] || snapshot.payload["hostName"] || snapshot.payload["platform"] || snapshot.payload.dig("meta", "hostName") || snapshot.payload.dig("meta", "crate")
%>

<div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold uppercase text-gray-400 mb-4">Latest Hyena ADSB Observation</h2>

  <dl class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Observation Time (UTC)</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= observed_label %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">ADSB Beacons Observed</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800"><%= obs_count %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Site</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= snapshot.payload.dig("geoLoc", "site") || "—" %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500 uppercase tracking-wide">Hostname</dt>
      <dd class="mt-1 text-sm font-mono text-gray-800">
        <%= hostname || "—" %>
      </dd>
    </div>
  </dl>

  <% if obs_rows.any? %>
    <h3 class="text-sm font-semibold text-gray-600 mb-2">
      ADSB Observations
      <% if obs_count > 15 %>
        <span class="text-xs font-normal text-gray-400">(showing 15 of <%= obs_count %>)</span>
      <% end %>
    </h3>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm" data-testid="adsb-table">
        <thead class="bg-gray-50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-3 py-2 text-left">ADSB Hex</th>
            <th class="px-3 py-2 text-left">Registration</th>
            <th class="px-3 py-2 text-left">Model</th>
            <th class="px-3 py-2 text-left">Flight</th>
            <th class="px-3 py-2 text-right">Altitude (ft)</th>
            <th class="px-3 py-2 text-right">Track (°)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% obs_rows.each do |obs| %>
            <% obs_hex = obs["adsbHex"] || obs["adsb_hex"] || obs["hex"] %>
            <% enrichment = adsbex_index[obs_hex.to_s.downcase] %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-mono text-gray-600"><%= obs_hex %></td>
              <td class="px-3 py-2 font-mono"><%= enrichment&.dig("registration") || "unknown" %></td>
              <td class="px-3 py-2 font-mono"><%= enrichment&.dig("model") || "unknown" %></td>
              <td class="px-3 py-2"><%= obs["flight"].presence || enrichment&.dig("flight") || "" %></td>
              <td class="px-3 py-2 text-right"><%= obs["altitude"] %></td>
              <td class="px-3 py-2 text-right"><%= obs["track"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic">No ADSB observations in this snapshot.</p>
  <% end %>

  <details class="mt-6 border-t border-gray-100 pt-4" data-testid="hyena-adsb-raw-json">
    <summary class="cursor-pointer text-sm font-semibold text-gray-600 hover:text-gray-800">
      Raw Payload JSON
    </summary>
    <pre class="mt-3 bg-gray-50 rounded p-4 text-sm overflow-x-auto text-gray-700"><%= JSON.pretty_generate(snapshot.payload) rescue snapshot.payload.to_s %></pre>
  </details>
</div>
