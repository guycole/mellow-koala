<nav class="p-4">
  <div class="mb-6">
    <%= link_to "Mellow Koala", root_path, class: "text-lg font-bold text-indigo-700 hover:text-indigo-900" %>
  </div>
  <div class="text-xs uppercase font-semibold text-gray-400 mb-2">Collectors</div>
  <% if defined?(nav_collectors) && nav_collectors.any? %>
    <% nav_collectors.each do |collector| %>
      <div class="mb-3">
        <div class="text-sm font-medium text-gray-700 mb-1"><%= collector.display_name %></div>
        <%= link_to "Details", collector_path(collector), class: "block pl-2 py-1 text-sm rounded #{'bg-indigo-50 text-indigo-700 font-medium' if current_page?(collector_path(collector))} hover:bg-gray-100" unless collector.collection_only? %>
        <%= link_to "Collection", collection_collector_path(collector), class: "block pl-2 py-1 text-sm rounded #{'bg-indigo-50 text-indigo-700 font-medium' if current_page?(collection_collector_path(collector))} hover:bg-gray-100" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sm text-gray-400 italic">No collectors yet</p>
  <% end %>
  <hr class="my-4 border-gray-200">
  <%= link_to "Carousel", carousel_path, class: "block py-1 text-sm rounded hover:bg-gray-100 #{'bg-indigo-50 text-indigo-700 font-medium' if current_page?(carousel_path)}" %>
</nav>
